rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // 1. Users (Profiles) Collection
    match /users/{userId} {
      // Users can view and update their own profile
      allow read, update: if isAuthenticated() && request.auth.uid == userId;
      // Users can create their profile on sign-up
      allow create: if isAuthenticated() && request.auth.uid == userId;
    }

    // 2. User Data Collection
    match /user_data/{docId} {
      // Users can only read, update, or delete data where the userId matches their auth uid
      allow read, update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
      
      // When inserting, the userId MUST match the person making the request
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
    }
  }
}
